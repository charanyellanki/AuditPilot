# Copy to `.env` and fill in. Never commit `.env` (see .gitignore).

# --- LLM provider ---
# Pick one provider for the active LLM path. Both keys may be set; the
# code selects based on LLM_PROVIDER below.
LLM_PROVIDER=anthropic            # anthropic | openai

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Model IDs (override per provider). Defaults chosen for cost/quality balance.
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o

# Judge model for the quote-grounded LLM-as-judge (can differ from the
# validation model to reduce shared-failure-mode bias).
JUDGE_MODEL=claude-sonnet-4-6

# --- Embeddings ---
# EMBEDDING_BACKEND=local uses a CPU sentence-transformer (no API cost).
# EMBEDDING_BACKEND=openai uses the OpenAI embeddings API.
EMBEDDING_BACKEND=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- ChromaDB ---
CHROMA_PERSIST_DIR=knowledge_base/chroma_db
CHROMA_COLLECTION=coding_guidance

# --- MLflow ---
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT=auditpilot-eval

# --- App ---
LOG_LEVEL=INFO
AUDIT_LOG_DIR=audit_log/logs
